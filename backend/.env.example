# .env.example
# ============================================
# gamers-store — Environment Variables Template
# ============================================
# Copy this file to ".env" in the same folder, then fill in YOUR OWN
# local values below. ".env" is in .gitignore and is NEVER pushed —
# only this template (.env.example) is committed to the repo.
#
# Option A setup: each teammate runs their own local SQL Server, so
# every value below should match YOUR OWN machine — never copy someone
# else's real .env values.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- SQL Server connection ---
# The machine SQL Server is running on. For a local install this is
# almost always "localhost".
DB_SERVER=localhost

# Most SQL Server Express installs use a named instance, commonly
# SQLEXPRESS. Confirm yours in SSMS's login screen — it shows something
# like YOURPCNAME\SQLEXPRESS. The part after the backslash goes here.
# Leave this blank if you're using DB_PORT instead below (they don't mix).
DB_INSTANCE=SQLEXPRESS

# Only set this if you are NOT using a named instance above.
DB_PORT=

DB_NAME=gamers_store

# --- SQL Server login ---
# Create this login yourself in SSMS: Security > Logins > New Login,
# with SQL Server authentication, then map it to the gamers_store
# database with the db_owner role.
DB_USER=
DB_PASSWORD=

# --- Auth ---
# Any long random string works — this is NOT a database credential.
# Generate one by running this once in a terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- CORS ---
# Must match the URL your Vite frontend runs on.
CORS_ORIGIN=http://localhost:5173
